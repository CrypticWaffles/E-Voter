<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Legislative Videos</h2>
    <a href="/analytics" class="btn btn-outline-primary btn-sm">National Results &rarr;</a>
  </div>
  <div class="row">
    <% videos.forEach(video => { %>
      <% const total = video.yesVotes + video.noVotes; %>
      <% const yesPct = total ? Math.round((video.yesVotes / total) * 100) : 0; %>
      <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
          <video class="card-img-top" style="max-height: 180px; object-fit: cover;" controls>
            <source src="<%= video.url %>" type="video/mp4">
            Your browser does not support the video tag.
          </video>
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= video.title %></h5>

            <% if (total > 0) { %>
              <div class="mt-auto mb-2">
                <div class="d-flex justify-content-between small text-muted mb-1">
                  <span class="text-success"><%= video.yesVotes %> Yes</span>
                  <span class="text-danger"><%= video.noVotes %> No</span>
                </div>
                <div class="progress" style="height: 8px;">
                  <div class="progress-bar bg-success" style="width: <%= yesPct %>%"></div>
                  <div class="progress-bar bg-danger" style="width: <%= 100 - yesPct %>%"></div>
                </div>
                <div class="text-muted small mt-1"><%= total %> vote<%= total !== 1 ? 's' : '' %></div>
              </div>
            <% } else { %>
              <div class="mt-auto mb-2 text-muted small">No votes yet — be the first!</div>
            <% } %>

            <a href="/video/play/<%= video.id %>" class="btn btn-primary btn-sm mt-2">Watch &amp; Vote</a>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
</div>
